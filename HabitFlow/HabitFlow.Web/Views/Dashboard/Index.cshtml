        @@media (max-width: 420px) {
            .stats-grid {
                grid-template-columns: 1fr 1fr !important;
            }

            .stat-value {
                font-size: 28px !important;
            }

            .habit-item,
            .quit-item {
                grid-template-columns: 10px 1fr auto !important;
                padding: 12px 10px !important;
            }

            .recommendation-card {
                padding: 14px !important;
            }
        }

    </style>
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#16a34a" />
    <link rel="apple-touch-icon" href="/icons/icon-192x192.png" />
    <link rel="icon" type="image/png" href="/icons/icon-192x192.png" />
</head>
<body>

    <nav class="navbar">
        <a asp-controller="Dashboard" asp-action="Index" class="logo">HabitFlow</a>
        <div class="nav-links">
            <a asp-controller="Dashboard" asp-action="Index" class="nav-link active">🏠 Дошка звичок</a>
            <a asp-controller="Habit" asp-action="Index" class="nav-link">📋 Мої звички</a>
            <a asp-controller="BalanceConstellation" asp-action="Index" class="nav-link">✨ Сузір'я балансу</a>
            <a asp-controller="Coach" asp-action="Index" class="nav-link">🤖 Агент</a>
            <a asp-controller="Profile" asp-action="Index" class="nav-link">👤 @Model.UserName</a>
            <a asp-controller="Auth" asp-action="Logout" class="btn-logout">Вийти</a>
        </div>
    </nav>

    <div class="container">

        @if (TempData["Success"] != null)
        {
            <div class="toast toast-success">✓ @TempData["Success"]</div>
        }

        <div class="page-header">
            <div>
                <div class="page-title">
                    @{
                        var hour = DateTime.Now.Hour;
                        var greeting = hour < 12 ? "Доброго ранку" : hour < 17 ? "Добрий день" : "Добрий вечір";
                    }
                    @greeting, @Model.UserName! 👋
                </div>
                <div class="page-subtitle">
                    @today.ToString("dddd, dd MMMM yyyy", new System.Globalization.CultureInfo("uk-UA"))
                    · Виконано @Model.CompletedToday з @regularHabits.Count звичок
                </div>
            </div>
            <a asp-controller="Habit" asp-action="Create" class="btn-add">+ Нова звичка</a>
        </div>

        <div class="stats-grid">
            <div class="stat-card green">
                <div class="stat-label">Виконано сьогодні</div>
                <div class="stat-value green">@Model.CompletedToday/@regularHabits.Count</div>
                <div class="stat-sub">звичок на сьогодні</div>
            </div>
            <div class="stat-card yellow">
                <div class="stat-label">Найдовша серія</div>
                <div class="stat-value yellow">@Model.LongestStreak</div>
                <div class="stat-sub">🔥 днів підряд</div>
            </div>
            <div class="stat-card blue">
                <div class="stat-label">Всього виконань</div>
                <div class="stat-value blue">@Model.TotalCompleted</div>
                <div class="stat-sub">за весь час</div>
            </div>
            <div class="stat-card purple">
                <div class="stat-label">Регулярність</div>
                <div class="stat-value purple">@Model.OverallConsistencyRate%</div>
                <div class="stat-sub">середнє виконання</div>
            </div>
        </div>

        @if (recommendations != null && recommendations.Any())
        {
            <div class="recommendations-section">
                <div class="recommendations-header">
                    <div class="recommendations-title">🤖 Рекомендації для тебе</div>
                    <div class="recommendations-badge">Персонально</div>
                </div>
                <div class="recommendations-grid">
                    @foreach (var item in recommendations)
                    {
                        <div class="recommendation-card @item.Type.ToLower()">
                            <div class="recommendation-icon">@item.Icon</div>
                            <div>
                                <div class="recommendation-title">@item.Title</div>
                                <div class="recommendation-message">@item.Message</div>
                                @if (item.HabitId != null)
                                {
                                    <a asp-controller="Analytics" asp-action="Index"
                                       asp-route-habitId="@item.HabitId" class="recommendation-link">
                                        Переглянути аналітику →
                                    </a>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="main-grid">
            <div class="card">
                <div class="card-header">
                    <div class="card-title">📅 Звички на сьогодні</div>
                    <a asp-controller="Habit" asp-action="Index" class="card-link">Всі звички →</a>
                </div>

                @if (!regularHabits.Any())
                {
                    <div class="empty-state">
                        <div class="empty-icon">🌱</div>
                        <p>У тебе ще немає звичок на сьогодні</p>
                        <a asp-controller="Habit" asp-action="Create" class="btn-add">+ Додати першу звичку</a>
                    </div>
                }
                else
                {
                    <div class="habits-list">
                        @foreach (var habit in regularHabits)
                        {
                            <div class="habit-item @(habit.IsCompletedToday ? "completed" : "")" id="habit-@habit.Id">
                                <div class="habit-color-dot" style="background:@habit.Color"></div>
                                <div class="habit-info">
                                    <div class="habit-name">@habit.Name</div>
                                    <div class="habit-meta">
                                        <span>@(habit.CurrentStreak > 0 ? $"🔥 {habit.CurrentStreak} дн." : "⚡ Починай!")</span>
                                        <span>·</span>
                                        <div class="mini-bar">
                                            <div class="mini-bar-fill" style="width:@habit.ConsistencyRate%;background:@habit.Color"></div>
                                        </div>
                                        <span>@habit.ConsistencyRate%</span>
                                    </div>
                                </div>
                                <button class="check-btn @(habit.IsCompletedToday ? "done" : "")"
                                        onclick="toggleHabit('@habit.Id', this)">
                                    @(habit.IsCompletedToday ? "✓" : "")
                                </button>
                            </div>
                        }
                    </div>
                }

                @if (quitHabits.Any())
                {
                    <hr class="section-divider" />
                    <div class="quit-section">
                        <div class="quit-section-title">
                            🚭 Кидаю звичку
                            <span style="font-size:11px;background:#fee2e2;color:#dc2626;padding:2px 8px;border-radius:100px;">
                                @quitHabits.Count
                            </span>
                        </div>
                        <div class="habits-list">
                            @foreach (var habit in quitHabits)
                            {
                                <div class="quit-item">
                                    <div class="habit-color-dot" style="background:@habit.Color"></div>
                                    <div class="quit-info">
                                        <div class="quit-name">@habit.Name</div>
                                        <div class="quit-stats">
                                            @if (habit.CleanDays > 0)
                                            {
                                                <span class="quit-badge quit-badge-days">🟢 @habit.CleanDays дн. чисто</span>
                                            }
                                            else
                                            {
                                                <span class="quit-badge quit-badge-risk-high">Починаємо сьогодні</span>
                                            }
                                            <span class="quit-stat">💪 @habit.DefeatedCravings потягів</span>
                                            @if (habit.RelapsesCount > 0)
                                            {
                                                <span class="quit-stat">❌ @habit.RelapsesCount зривів</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="quit-actions">
                                        <form asp-controller="QuitHabit" asp-action="LogCleanDay" method="post" style="display:inline">
                                            <input type="hidden" name="habitId" value="@habit.Id" />
                                            <button type="submit" class="quit-btn quit-btn-clean" title="Чистий день">✅</button>
                                        </form>
                                        <form asp-controller="QuitHabit" asp-action="LogCraving" method="post" style="display:inline">
                                            <input type="hidden" name="habitId" value="@habit.Id" />
                                            <input type="hidden" name="CravingLevel" value="5" />
                                            <input type="hidden" name="TriggerType" value="Other" />
                                            <button type="submit" class="quit-btn quit-btn-craving" title="Потяг">⚡</button>
                                        </form>
                                        <form asp-controller="QuitHabit" asp-action="LogRelapse" method="post" style="display:inline">
                                            <input type="hidden" name="habitId" value="@habit.Id" />
                                            <input type="hidden" name="CravingLevel" value="10" />
                                            <input type="hidden" name="TriggerType" value="0" />
                                            <button type="submit" class="quit-btn quit-btn-support" title="Зрив">❌</button>
                                        </form>
                                    </div>
                                </div>
                            }
                        </div>
                        <div style="margin-top:12px;">
                            <a asp-controller="Quit" asp-action="Index"
                               style="font-size:13px;color:#dc2626;text-decoration:none;font-weight:600;">
                                Детальна аналітика відмови →
                            </a>
                        </div>
                    </div>
                }
            </div>

            <div class="sidebar">
                <div class="card">
                    <div class="card-title" style="margin-bottom:4px">🗓 Активність за рік</div>
                    <div class="heatmap-grid">
                        @foreach (var day in Model.HeatmapData)
                        {
                            <div class="hm-cell @(day.Level > 0 ? $"l{day.Level}" : "")"
                                 title="@day.Date.ToString("dd.MM.yyyy"): @day.CompletedCount виконань"></div>
                        }
                    </div>
                    <div class="hm-legend">
                        <span>Менше</span>
                        <div class="hm-legend-cell" style="background:#f3f4f6"></div>
                        <div class="hm-legend-cell" style="background:#bbf7d0"></div>
                        <div class="hm-legend-cell" style="background:#4ade80"></div>
                        <div class="hm-legend-cell" style="background:#16a34a"></div>
                        <div class="hm-legend-cell" style="background:#14532d"></div>
                        <span>Більше</span>
                    </div>
                </div>

                @if (quitHabits.Any())
                {
                    <div class="card">
                        <div class="card-title" style="margin-bottom:4px">🚭 Активність відмови</div>
                        <div class="heatmap-grid">
                            @foreach (var day in Model.QuitHeatmapData)
                            {
                                <div class="hm-cell @(day.Level > 0 ? $"q{day.Level}" : "")"
                                     title="@day.Date.ToString("dd.MM.yyyy"): @(day.Level == 1 ? "зрив" : day.CompletedCount > 0 ? $"{day.CompletedCount} чистих дн." : "немає даних")"></div>
                            }
                        </div>
                        <div class="hm-legend">
                            <span>Зрив</span>
                            <div class="hm-legend-cell" style="background:#f3f4f6"></div>
                            <div class="hm-legend-cell" style="background:#fca5a5"></div>
                            <div class="hm-legend-cell" style="background:#4ade80"></div>
                            <span>Чисто</span>
                        </div>
                    </div>
                }

                <div class="card">
                    <div class="card-title" style="margin-bottom:14px">💡 Інсайти</div>

                    @if (!Model.TodayHabits.Any())
                    {
                        <div class="insight-item">
                            <div class="insight-icon">🌱</div>
                            <div class="insight-text">Додай свою першу звичку і почни відстеження прогресу!</div>
                        </div>
                    }
                    else
                    {
                        @if (Model.CompletedToday == regularHabits.Count && regularHabits.Any())
                        {
                            <div class="insight-item">
                                <div class="insight-icon">🎉</div>
                                <div class="insight-text"><strong>Всі звички виконані!</strong> Чудовий день!</div>
                            </div>
                        }
                        else if (Model.CompletedToday == 0 && regularHabits.Any())
                        {
                            <div class="insight-item">
                                <div class="insight-icon">⚡</div>
                                <div class="insight-text">Сьогодні ще нічого не виконано. Починай прямо зараз!</div>
                            </div>
                        }
                        else if (regularHabits.Any())
                        {
                            <div class="insight-item">
                                <div class="insight-icon">🔥</div>
                                <div class="insight-text">
                                    Виконано <strong>@Model.CompletedToday з @regularHabits.Count</strong>.
                                    Залишилось ще @(regularHabits.Count - Model.CompletedToday)!
                                </div>
                            </div>
                        }

                        @if (quitHabits.Any())
                        {
                            var bestQuit = quitHabits.OrderByDescending(q => q.CleanDays).First();
                            <div class="insight-item">
                                <div class="insight-icon">🚭</div>
                                <div class="insight-text">
                                    <strong>@bestQuit.Name</strong>: @bestQuit.CleanDays чистих днів.
                                    @if (bestQuit.DefeatedCravings > 0)
                                    {
                                        <span>Переможено @bestQuit.DefeatedCravings потягів!</span>
                                    }
                                </div>
                            </div>
                        }

                        @if (Model.LongestStreak >= 7)
                        {
                            <div class="insight-item">
                                <div class="insight-icon">🏆</div>
                                <div class="insight-text">Серія <strong>@Model.LongestStreak днів</strong> — ти на правильному шляху!</div>
                            </div>
                        }

                        @if (Model.TotalCompleted >= 1)
                        {
                            <div class="insight-item">
                                <div class="insight-icon">📊</div>
                                <div class="insight-text">Загальна регулярність: <strong>@Model.OverallConsistencyRate%</strong></div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <script>
            async function toggleHabit(habitId, btn) {
                try {
                    const response = await fetch('/Habit/Toggle/' + habitId, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' }
                    });
                    const data = await response.json();
                    if (data.success) {
                        const item = document.getElementById('habit-' + habitId);
                        if (data.completed) {
                            item.classList.add('completed');
                            btn.classList.add('done');
                            btn.textContent = '✓';
                        } else {
                            item.classList.remove('completed');
                            btn.classList.remove('done');
                            btn.textContent = '';
                        }
                    }
                } catch (e) { console.error('Error:', e); }
            }
    </script>
    <script>
            if ('serviceWorker' in navigator) {
              navigator.serviceWorker.register('/service-worker.js');
            }
    </script>
</body>
</html>

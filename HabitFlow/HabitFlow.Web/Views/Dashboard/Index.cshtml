@{
    ViewData["Title"] = "Дашборд";
}
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <title>HabitFlow — Дашборд</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; background: #f0fdf4; }
        .navbar {
            background: white;
            padding: 16px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 1px 8px rgba(0,0,0,0.06);
        }
        .logo { font-size: 20px; font-weight: 700; color: #16a34a; }
        .nav-right { display: flex; align-items: center; gap: 16px; }
        .user-name { font-size: 14px; color: #374151; font-weight: 500; }
        .btn-logout {
            padding: 8px 16px;
            background: #f3f4f6;
            color: #374151;
            border: none;
            border-radius: 8px;
            font-family: 'Inter', sans-serif;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
        }
        .btn-logout:hover { background: #e5e7eb; }
        .container { max-width: 1100px; margin: 40px auto; padding: 0 24px; }
        .welcome {
            font-size: 26px;
            font-weight: 700;
            color: #111827;
            margin-bottom: 8px;
        }
        .subtitle { font-size: 15px; color: #6b7280; margin-bottom: 32px; }
        .coming-soon {
            background: white;
            border-radius: 16px;
            padding: 60px;
            text-align: center;
            box-shadow: 0 2px 16px rgba(0,0,0,0.06);
        }
        .coming-soon h2 { font-size: 20px; color: #374151; margin-bottom: 8px; }
        .coming-soon p { font-size: 14px; color: #9ca3af; }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="logo">HabitFlow</div>
        <div class="nav-right">
            <span class="user-name">👋 @ViewBag.UserName</span>
            <a href="/Auth/Logout" class="btn-logout">Вийти</a>
        </div>
    </nav>
    <div class="container">
        <div class="welcome">Добрий день, @ViewBag.UserName! 👋</div>
        <div class="subtitle">Готовий будувати нові звички?</div>
        <div class="coming-soon">
            <h2>🚀 Дашборд в розробці</h2>
            <p>Скоро тут буде твоя аналітика та звички</p>
        </div>
    </div>
</body>
</html>
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — HabitFlow</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #f0fdf4;
        }

        .navbar {
            background: white !important;
            box-shadow: 0 1px 8px rgba(0,0,0,0.06);
            padding: 12px 24px;
        }

        .navbar-brand {
            font-size: 20px;
            font-weight: 700;
            color: #16a34a !important;
        }

        .nav-link {
            font-size: 14px;
            font-weight: 500;
            color: #374151 !important;
        }

        .btn-register {
            background: #16a34a;
            color: white !important;
            border-radius: 8px;
            padding: 8px 18px !important;
            font-weight: 600 !important;
        }

            .btn-register:hover {
                background: #15803d;
            }

        .btn-login {
            border: 1.5px solid #16a34a;
            color: #16a34a !important;
            border-radius: 8px;
            padding: 7px 18px !important;
            font-weight: 600 !important;
        }

        .btn-logout {
            background: #f3f4f6;
            color: #374151 !important;
            border-radius: 8px;
            padding: 8px 16px !important;
            font-size: 13px;
            font-weight: 500;
        }

        .avatar {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            object-fit: cover;
        }

        .profile-link {
            display: flex;
            align-items: center;
            gap: 8px;
        }
    </style>
</head>

<body>
    @Html.AntiForgeryToken()
    <header>
        <nav class="navbar navbar-expand-sm navbar-light">
            <div class="container-fluid">

                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    HabitFlow
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">

                    <ul class="navbar-nav ms-auto align-items-center gap-2">

                        @if (Context.Session.GetString("UserId") != null)
                        {
                            <!-- DASHBOARD -->
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Dashboard"
                                   asp-action="Index">
                                    🏠 Дашборд
                                </a>
                            </li>

                            <!-- HABITS -->
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Habit"
                                   asp-action="Index">
                                    📋 Мої звички
                                </a>
                            </li>

                            <!-- PROFILE -->
                            <li class="nav-item">
                                <a class="nav-link profile-link"
                                   asp-controller="Profile"
                                   asp-action="Index">

                                    <img src="/images/default-avatar.png"
                                         class="avatar" />

                                    <span>@Context.Session.GetString("UserName")</span>
                                </a>
                            </li>

                            <!-- LOGOUT -->
                            <li class="nav-item">
                                <a class="nav-link btn-logout"
                                   asp-controller="Auth"
                                   asp-action="Logout">
                                    Вийти
                                </a>
                            </li>
                        }
                        else
                        {
                            <!-- LOGIN -->
                            <li class="nav-item">
                                <a class="nav-link btn-login"
                                   asp-controller="Auth"
                                   asp-action="Login">
                                    Увійти
                                </a>
                            </li>

                            <!-- REGISTER -->
                            <li class="nav-item">
                                <a class="nav-link btn-register"
                                   asp-controller="Auth"
                                   asp-action="Register">
                                    Зареєструватись
                                </a>
                            </li>
                        }

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div>
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
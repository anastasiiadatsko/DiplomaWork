@{
    Layout = null;
    var isSuccess = ViewBag.IsSuccess == true;
    var message = ViewBag.Message as string ?? "Результат обробки запрошення";
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <title>HabitFlow — Запрошення</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #f0fdf4;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            background: white;
            border-radius: 24px;
            padding: 56px 44px;
            text-align: center;
            max-width: 480px;
            width: 100%;
            margin: 24px;
            box-shadow: 0 4px 40px rgba(0,0,0,0.08);
        }

        .icon {
            font-size: 56px;
            margin-bottom: 20px;
        }

        h1 {
            font-size: 24px;
            font-weight: 700;
            color: #111827;
            margin-bottom: 12px;
        }

        p {
            font-size: 15px;
            color: #6b7280;
            line-height: 1.6;
            margin-bottom: 28px;
        }

        .btn {
            display: inline-block;
            background: #16a34a;
            color: white;
            padding: 12px 28px;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 600;
            text-decoration: none;
        }

            .btn:hover {
                background: #15803d;
            }

        .error {
            background: #ef4444;
        }

            .error:hover {
                background: #dc2626;
            }
    </style>
</head>
<body>
    <div class="card">
        <div class="icon">@(isSuccess ? "✅" : "⚠️")</div>

        <h1>@(isSuccess ? "Готово!" : "Не вдалося")</h1>

        <p>@message</p>

        <a asp-controller="Auth"
           asp-action="Login"
           class="btn @(isSuccess ? "" : "error")">
            Перейти до входу
        </a>
    </div>
</body>
</html>
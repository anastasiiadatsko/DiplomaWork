@using HabitFlow.BLL.DTOs

@{
    ViewData["Title"] = "Кризова підтримка";
    var analytics = ViewBag.Analytics as QuitAnalyticsViewModel;
    var initialMode = Context.Request.Query["mode"].ToString() == "afterRelapse"
        ? "AfterRelapse"
        : "CravingSupport";
}

<div class="crisis-page">

    <div class="crisis-header">
        <a href="@Url.Action("Index", "Quit")" class="back-link">← Аналітика відмови</a>
        <h1>Підтримка в кризовий момент</h1>
    </div>

    <div class="mode-tabs">
        <button class="tab @(initialMode == "CravingSupport" ? "active" : "")"
                onclick="setMode('CravingSupport', this)">
            🔥 Зараз потяг
        </button>
        <button class="tab @(initialMode == "AfterRelapse" ? "active" : "")"
                onclick="setMode('AfterRelapse', this)">
            💔 Стався зрив
        </button>
        <button class="tab" onclick="setMode('Prevention', this)">
            🛡️ Профілактика
        </button>
    </div>

    <div id="craving-panel" class="mode-panel @(initialMode == "CravingSupport" ? "" : "hidden")">
        <p class="panel-desc">Потяг — це хвиля. Скажи яка сила і що спровокувало — отримай план на наступні 15 хвилин.</p>
        <div class="form-row">
            <label>Сила зараз: <strong id="intensity-label">5</strong>/10</label>
            <input type="range" id="craving-intensity" min="1" max="10" value="5"
                   oninput="document.getElementById('intensity-label').textContent = this.value" />
        </div>
        <div class="form-row">
            <input type="text" id="craving-trigger" placeholder="Що спровокувало? (необов'язково)" />
        </div>
    </div>

    <div id="relapse-panel" class="mode-panel @(initialMode == "AfterRelapse" ? "" : "hidden")">
        <p class="panel-desc">Зрив — це частина шляху. Розкажи що сталось, щоб рухатись далі.</p>
    </div>

    <div id="prevention-panel" class="mode-panel hidden">
        <p class="panel-desc">Підготуйся до ризикових ситуацій заздалегідь.</p>
    </div>

    <div class="chat-area" id="chat-area"></div>

    <div class="recording-indicator" id="recordingIndicator">
        <div class="rec-dot"></div>
        Слухаю... говори українською
        <button onclick="stopLiveSession()" class="btn-stop-recording">
            ⏹ Зупинити
        </button>
    </div>

    <div class="tts-status-bar" id="ttsStatusBar">
        <div class="tts-wave">
            <span></span><span></span><span></span><span></span><span></span>
        </div>
        Агент говорить...
        <button onclick="stopLiveAudio()" class="btn-stop-tts">⏹ Зупинити</button>
    </div>

    <div class="chat-input-row">
        <input type="text" id="user-input"
               placeholder="Напиши що відчуваєш або постав питання..."
               onkeydown="if(event.key==='Enter') sendMessage()" />
        <button class="btn-voice" id="btn-voice" onclick="toggleVoiceChat()" type="button" title="Голосовий режим">🎙️</button>
        <button onclick="sendMessage()" id="send-btn">Надіслати</button>
    </div>

    @if (analytics != null && analytics.CleanDays > 0)
    {
        <div class="reminder-block">
            <span>Ти вже тримаєшся <strong>@analytics.CleanDays</strong> @(analytics.CleanDays == 1 ? "день" : analytics.CleanDays < 5 ? "дні" : "днів") поспіль.</span>
        </div>
    }

</div>

<style>
    .crisis-page {
        max-width: 700px;
        margin: 0 auto;
        padding: 24px 16px;
    }

    .crisis-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 24px;
    }

    .back-link {
        color: #3182ce;
        text-decoration: none;
        font-size: 0.9rem;
        white-space: nowrap;
    }

    .crisis-header h1 {
        font-size: 1.4rem;
        font-weight: 700;
        margin: 0;
    }

    .mode-tabs {
        display: flex;
        gap: 8px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .tab {
        padding: 8px 16px;
        border: 2px solid #e2e8f0;
        border-radius: 20px;
        background: #fff;
        cursor: pointer;
        font-size: 0.88rem;
        font-weight: 600;
        color: #4a5568;
        transition: all 0.2s;
    }

        .tab.active {
            border-color: #e53e3e;
            background: #fff5f5;
            color: #c53030;
        }

        .tab:hover {
            border-color: #cbd5e0;
            background: #f7fafc;
        }

    .mode-panel {
        margin-bottom: 16px;
    }

        .mode-panel.hidden {
            display: none;
        }

    .panel-desc {
        font-size: 0.92rem;
        color: #4a5568;
        margin: 0 0 12px;
    }

    .form-row {
        margin-bottom: 10px;
    }

        .form-row label {
            display: block;
            font-size: 0.88rem;
            font-weight: 600;
            margin-bottom: 4px;
        }

        .form-row input[type="range"] {
            width: 100%;
        }

        .form-row input[type="text"] {
            width: 100%;
            padding: 8px 12px;
            border: 1px solid #cbd5e0;
            border-radius: 8px;
            font-size: 0.92rem;
            box-sizing: border-box;
        }

    .chat-area {
        min-height: 200px;
        max-height: 420px;
        overflow-y: auto;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 16px;
        margin-bottom: 12px;
        background: #f7fafc;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .msg {
        max-width: 85%;
        padding: 10px 14px;
        border-radius: 12px;
        font-size: 0.92rem;
        line-height: 1.5;
    }

        .msg.user {
            background: #3182ce;
            color: #fff;
            align-self: flex-end;
            border-bottom-right-radius: 4px;
        }

        .msg.coach {
            background: #fff;
            border: 1px solid #e2e8f0;
            align-self: flex-start;
            border-bottom-left-radius: 4px;
        }

            .msg.coach .actions {
                margin-top: 10px;
                padding-top: 10px;
                border-top: 1px solid #e2e8f0;
            }

                .msg.coach .actions p {
                    margin: 4px 0;
                    font-size: 0.88rem;
                    color: #2d3748;
                }

            .msg.coach .note {
                margin-top: 8px;
                font-size: 0.85rem;
                color: #718096;
                font-style: italic;
            }

        .msg.loading {
            color: #a0aec0;
            font-style: italic;
        }

    /* Голосовий індикатор запису */
    .recording-indicator {
        display: none;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        background: #fef2f2;
        border-radius: 12px;
        margin-bottom: 10px;
        font-size: 0.82rem;
        color: #e53e3e;
        font-weight: 600;
    }

        .recording-indicator.visible {
            display: flex;
        }

    .rec-dot {
        width: 10px;
        height: 10px;
        background: #e53e3e;
        border-radius: 50%;
        animation: pulse 1s infinite;
    }

    .btn-stop-recording {
        margin-left: auto;
        font-size: 0.75rem;
        font-weight: 600;
        border: 1px solid #e53e3e;
        border-radius: 8px;
        background: white;
        padding: 2px 8px;
        cursor: pointer;
        color: #e53e3e;
    }

    /* Голосовий індикатор відтворення */
    .tts-status-bar {
        display: none;
        align-items: center;
        gap: 8px;
        padding: 6px 0 10px;
        font-size: 0.8rem;
        color: #276749;
    }

        .tts-status-bar.visible {
            display: flex;
        }

    .tts-wave {
        display: flex;
        align-items: center;
        gap: 2px;
    }

        .tts-wave span {
            display: block;
            width: 3px;
            background: #16a34a;
            border-radius: 2px;
            animation: wave 0.8s ease-in-out infinite;
        }

            .tts-wave span:nth-child(1) {
                height: 8px;
                animation-delay: 0s;
            }

            .tts-wave span:nth-child(2) {
                height: 14px;
                animation-delay: .1s;
            }

            .tts-wave span:nth-child(3) {
                height: 10px;
                animation-delay: .2s;
            }

            .tts-wave span:nth-child(4) {
                height: 16px;
                animation-delay: .15s;
            }

            .tts-wave span:nth-child(5) {
                height: 8px;
                animation-delay: .05s;
            }

    .btn-stop-tts {
        font-size: 0.75rem;
        font-weight: 600;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        background: white;
        padding: 2px 8px;
        cursor: pointer;
        color: #718096;
    }

    @@keyframes pulse {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: .4;
        }
    }

    @@keyframes wave {
        0%, 100% {
            transform: scaleY(1);
        }

        50% {
            transform: scaleY(.4);
        }
    }

    /* Рядок вводу */
    .chat-input-row {
        display: flex;
        gap: 8px;
        margin-bottom: 16px;
        align-items: center;
    }

        .chat-input-row input {
            flex: 1;
            padding: 10px 14px;
            border: 1px solid #cbd5e0;
            border-radius: 8px;
            font-size: 0.92rem;
        }

        .chat-input-row button {
            background: #e53e3e;
            color: #fff;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }

            .chat-input-row button:hover {
                background: #c53030;
            }

            .chat-input-row button:disabled {
                background: #a0aec0;
                cursor: not-allowed;
            }

    /* Кнопка голосу */
    .btn-voice {
        width: 44px;
        height: 44px;
        padding: 0 !important;
        background: white !important;
        color: #4a5568 !important;
        border: 2px solid #e2e8f0 !important;
        border-radius: 10px !important;
        font-size: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .btn-voice:hover {
            border-color: #e53e3e !important;
        }

        .btn-voice.recording {
            background: #fff5f5 !important;
            border-color: #e53e3e !important;
            animation: pulse 1s infinite;
        }

    .reminder-block {
        background: #f0fff4;
        border: 1px solid #9ae6b4;
        border-radius: 8px;
        padding: 12px 16px;
        font-size: 0.9rem;
        color: #276749;
        text-align: center;
    }
</style>

<script>
    let currentMode = '@initialMode';
    let chatHistory = [];

    // ── Стан голосового чату ──────────────────────────────────────
    let liveWs = null;
    let liveAudioCtx = null;
    let liveProcessor = null;
    let liveIsActive = false;

    let livePlaybackCtx = null;
    let liveNextStartTime = 0;
    let liveHasAudio = false;

    const _transcriptBuf   = { model: '', user: '' };
    const _transcriptTimer = { model: null, user: null };

    // ── Перемикання режимів ───────────────────────────────────────
    function setMode(mode, btn) {
        currentMode = mode;
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('craving-panel').classList.toggle('hidden', mode !== 'CravingSupport');
        document.getElementById('relapse-panel').classList.toggle('hidden', mode !== 'AfterRelapse');
        document.getElementById('prevention-panel').classList.toggle('hidden', mode !== 'Prevention');
    }

    // ── Текстовий чат ─────────────────────────────────────────────
    function appendMsg(role, content, actions, note) {
        const area = document.getElementById('chat-area');
        const div  = document.createElement('div');
        div.className = `msg ${role}`;

        if (role === 'coach') {
            let html = `<div>${escHtml(content)}</div>`;
            if (actions && actions.length) {
                html += `<div class="actions">`;
                actions.forEach(a => { html += `<p>→ ${escHtml(a)}</p>`; });
                html += `</div>`;
            }
            if (note) html += `<div class="note">${escHtml(note)}</div>`;
            div.innerHTML = html;
        } else {
            div.textContent = content;
        }

        area.appendChild(div);
        area.scrollTop = area.scrollHeight;
        return div;
    }

    function escHtml(s) {
        return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    async function sendMessage() {
        const input = document.getElementById('user-input');
        const btn   = document.getElementById('send-btn');
        const text  = input.value.trim();

        const request = {
            Mode: currentMode,
            UserMessage: text || null,
            History: chatHistory,
        };

        if (currentMode === 'CravingSupport') {
            request.CurrentIntensity = parseInt(document.getElementById('craving-intensity').value);
            const trig = document.getElementById('craving-trigger').value.trim();
            if (trig) request.TriggerDescription = trig;
        }

        if (!text && currentMode !== 'CravingSupport' && currentMode !== 'AfterRelapse') return;

        if (text) {
            appendMsg('user', text);
            chatHistory.push({ Role: 'user', Content: text });
        }

        input.value  = '';
        btn.disabled = true;
        const loading = appendMsg('coach', 'Думаю...');
        loading.classList.add('loading');

        try {
            const resp = await fetch('@Url.Action("Coach", "Quit")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(request),
            });

            const data = await resp.json();
            loading.remove();

            appendMsg('coach', data.message, data.suggestedActions, data.motivationalNote);
            chatHistory.push({ Role: 'coach', Content: data.message });

        } catch {
            loading.textContent = "Помилка з'єднання. Спробуй ще раз.";
            loading.classList.remove('loading');
        } finally {
            btn.disabled = false;
        }
    }

    function showTtsBar(visible) {
        document.getElementById('ttsStatusBar').classList.toggle('visible', visible);
    }

    async function toggleVoiceChat() {
        if (liveIsActive) stopLiveSession();
        else await startLiveSession();
    }

    async function startLiveSession() {
        const btn = document.getElementById('btn-voice');
        btn.textContent = '⏳';
        btn.disabled    = true;

        let userId = '';
        try {
            const resp = await fetch('/Coach/GetUserId');
            const data = await resp.json();
            userId = data.userId;
            if (!userId) throw new Error('userId null');
        } catch (e) {
            console.error('Помилка userId:', e);
            btn.textContent = '🎙️';
            btn.disabled    = false;
            appendMsg('coach', '⚠️ Помилка авторизації. Перезайди в акаунт.');
            return;
        }

        livePlaybackCtx  = new AudioContext({ sampleRate: 24000 });
        liveNextStartTime = 0;
        liveHasAudio      = false;

        const proto  = location.protocol === 'https:' ? 'wss' : 'ws';
       const wsUrl = `${proto}://${location.host}/Quit/VoiceStream?userId=${userId}`;

        liveWs = new WebSocket(wsUrl);
        liveWs.binaryType = 'arraybuffer';

        liveWs.onopen = async () => {
            liveIsActive     = true;
            btn.textContent  = '⏹';
            btn.disabled     = false;
            btn.classList.add('recording');
            document.getElementById('recordingIndicator').classList.add('visible');
            await startLiveMicrophone();
        };

        liveWs.onmessage = (e) => {
            const text = typeof e.data === 'string'
                ? e.data
                : new TextDecoder().decode(e.data);
            handleLiveMessage(text);
        };

        liveWs.onclose = () => stopLiveSession();

        liveWs.onerror = (e) => {
            console.error('WS помилка:', e);
            stopLiveSession();
            appendMsg('coach', "⚠️ Не вдалось підключитись до голосового агента. Спробуй ще раз.");
        };
    }

    function handleLiveMessage(json) {
        let msg;
        try { msg = JSON.parse(json); } catch { return; }

        const parts = msg?.serverContent?.modelTurn?.parts ?? [];
        for (const p of parts) {
            if (p?.inlineData?.mimeType?.startsWith('audio/')) {
                schedulePcmChunk(p.inlineData.data);
            }
        }

        // Транскрипт агента
        const outText = msg?.serverContent?.outputTranscription?.text
                     ?? msg?.serverContent?.outputAudioTranscription?.text;
        if (outText) accumulateTranscript('model', outText);

        // Транскрипт користувача
        const inText = msg?.serverContent?.inputTranscription?.text
                    ?? msg?.serverContent?.inputAudioTranscription?.text;
        if (inText) accumulateTranscript('user', inText);
    }

    function accumulateTranscript(role, chunk) {
        _transcriptBuf[role] += chunk;
        clearTimeout(_transcriptTimer[role]);
        _transcriptTimer[role] = setTimeout(() => {
            const text = _transcriptBuf[role].trim();
            if (text) {
                chatHistory.push({ Role: role === 'model' ? 'coach' : 'user', Content: text });
                if (role === 'model') appendMsg('coach', text);
                else                  appendMsg('user', text);
            }
            _transcriptBuf[role] = '';
        }, 800);
    }

    function schedulePcmChunk(b64) {
        if (!livePlaybackCtx) return;

        const samples  = pcmBase64ToFloat32(b64);
        const duration = samples.length / 24000;

        const buf = livePlaybackCtx.createBuffer(1, samples.length, 24000);
        buf.copyToChannel(samples, 0);

        const src = livePlaybackCtx.createBufferSource();
        src.buffer = buf;
        src.connect(livePlaybackCtx.destination);

        if (!liveHasAudio) {
            liveNextStartTime = livePlaybackCtx.currentTime + 0.1;
            liveHasAudio      = true;
            showTtsBar(true);
        }

        src.start(liveNextStartTime);
        liveNextStartTime += duration;

        src.onended = () => {
            if (livePlaybackCtx && liveNextStartTime <= livePlaybackCtx.currentTime + 0.05) {
                showTtsBar(false);
                liveHasAudio = false;
            }
        };
    }

    function stopLiveAudio() {
        if (livePlaybackCtx) {
            livePlaybackCtx.close().catch(() => {});
            livePlaybackCtx = null;
        }
        liveNextStartTime = 0;
        liveHasAudio      = false;
        showTtsBar(false);
    }

    async function startLiveMicrophone() {
        try {
            liveAudioCtx = new AudioContext({ sampleRate: 16000 });
            const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
            const source = liveAudioCtx.createMediaStreamSource(stream);

            await liveAudioCtx.audioWorklet.addModule('/js/pcm-processor.js');
            liveProcessor = new AudioWorkletNode(liveAudioCtx, 'pcm-processor');

            liveProcessor.port.onmessage = ({ data }) => {
                if (liveWs?.readyState === WebSocket.OPEN) {
                    liveWs.send(JSON.stringify({
                        realtime_input: {
                            media_chunks: [{
                                mime_type: 'audio/pcm;rate=16000',
                                data: arrayBufferToBase64(data)
                            }]
                        }
                    }));
                }
            };

            source.connect(liveProcessor);
            liveProcessor.connect(liveAudioCtx.destination);
        } catch (e) {
            console.error('startLiveMicrophone помилка:', e);
            appendMsg('coach', '⚠️ Не вдалось підключити мікрофон: ' + e.message);
        }
    }

    function stopLiveSession() {
        liveIsActive = false;

        clearTimeout(_transcriptTimer.model);
        clearTimeout(_transcriptTimer.user);
        _transcriptBuf.model = '';
        _transcriptBuf.user  = '';

        liveProcessor?.disconnect();
        liveAudioCtx?.close().catch(() => {});
        liveAudioCtx = null;
        liveProcessor = null;

        stopLiveAudio();

        if (liveWs) {
            liveWs.onclose = null;
            liveWs.close();
            liveWs = null;
        }

        const btn = document.getElementById('btn-voice');
        btn.textContent = '🎙️';
        btn.disabled    = false;
        btn.classList.remove('recording');
        document.getElementById('recordingIndicator').classList.remove('visible');
    }

    // ── PCM helpers ───────────────────────────────────────────────
    function pcmBase64ToFloat32(b64) {
        const bin   = atob(b64);
        const bytes = new Uint8Array(bin.length);
        for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
        const i16 = new Int16Array(bytes.buffer);
        const f32 = new Float32Array(i16.length);
        for (let i = 0; i < i16.length; i++) f32[i] = i16[i] / 32768;
        return f32;
    }

    function arrayBufferToBase64(buf) {
        let s = '';
        new Uint8Array(buf).forEach(b => s += String.fromCharCode(b));
        return btoa(s);
    }

    // ── Старт ─────────────────────────────────────────────────────
    window.addEventListener('DOMContentLoaded', () => {
        if (currentMode === 'CravingSupport' || currentMode === 'AfterRelapse') {
            sendMessage();
        }
    });
</script>

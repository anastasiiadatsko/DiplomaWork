@model HabitFlow.BLL.DTOs.RegisterDto
@{
    ViewData["Title"] = "Реєстрація";
    Layout = null;
}
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HabitFlow — Реєстрація</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #f0fdf4;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .page-wrapper {
            display: flex;
            width: 100%;
            max-width: 900px;
            background: #ffffff;
            border-radius: 24px;
            box-shadow: 0 4px 40px rgba(0,0,0,0.08);
            overflow: hidden;
            margin: 24px;
        }

        .left-panel {
            flex: 1;
            background: linear-gradient(145deg, #16a34a, #15803d);
            padding: 48px 40px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            color: white;
        }

        .logo {
            font-size: 24px;
            font-weight: 700;
        }

            .logo span {
                opacity: 0.75;
            }

        .left-content h1 {
            font-size: 28px;
            font-weight: 700;
            line-height: 1.3;
            margin-bottom: 12px;
        }

        .left-content p {
            font-size: 14px;
            opacity: 0.85;
            line-height: 1.6;
        }

        .features {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .feature-item {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 14px;
            opacity: 0.9;
        }

        .feature-icon {
            width: 28px;
            height: 28px;
            background: rgba(255,255,255,0.2);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            flex-shrink: 0;
        }

        .right-panel {
            flex: 1;
            padding: 48px 40px;
        }

        .form-header {
            margin-bottom: 28px;
        }

            .form-header h2 {
                font-size: 22px;
                font-weight: 700;
                color: #111827;
                margin-bottom: 6px;
            }

            .form-header p {
                font-size: 14px;
                color: #6b7280;
            }

            .form-header a {
                color: #16a34a;
                text-decoration: none;
                font-weight: 500;
            }

        .form-group {
            margin-bottom: 14px;
        }

        label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: #374151;
            margin-bottom: 5px;
        }

        input {
            width: 100%;
            padding: 10px 14px;
            border: 1.5px solid #e5e7eb;
            border-radius: 10px;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            color: #111827;
            background: #f9fafb;
            transition: border-color 0.2s;
            outline: none;
        }

            input:focus {
                border-color: #16a34a;
                background: #fff;
            }

        .error-message {
            font-size: 12px;
            color: #dc2626;
            margin-top: 4px;
            display: block;
        }

        .validation-summary {
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 10px;
            padding: 12px 14px;
            margin-bottom: 16px;
            font-size: 13px;
            color: #dc2626;
        }

        .btn-submit {
            width: 100%;
            padding: 12px;
            background: #16a34a;
            color: white;
            border: none;
            border-radius: 10px;
            font-family: 'Inter', sans-serif;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s;
            margin-top: 8px;
        }

            .btn-submit:hover {
                background: #15803d;
            }

        /* MOBILE REGISTER FIX */
        @@media (max-width: 768px) {
            html,
            body {
                width: 100%;
                min-height: 100vh;
                overflow-x: hidden;
            }

            body {
                padding: 0;
                align-items: center;
                justify-content: center;
            }

            .page-wrapper {
                width: calc(100% - 28px) !important;
                max-width: 430px !important;
                min-width: 0 !important;
                margin: 20px auto !important;
                display: block !important;
                border-radius: 24px !important;
                overflow: hidden !important;
            }

            .left-panel {
                display: none !important;
            }

            .right-panel {
                width: 100% !important;
                max-width: 100% !important;
                min-width: 0 !important;
                padding: 28px 22px !important;
                display: block !important;
            }

            .form-header h2 {
                font-size: 25px !important;
                line-height: 1.2 !important;
            }

            .form-header p {
                font-size: 13px !important;
                line-height: 1.4 !important;
            }

            .features {
                display: none !important;
            }

            form,
            .form-group {
                width: 100% !important;
            }

            input {
                width: 100% !important;
                max-width: 100% !important;
                font-size: 14px !important;
            }

            .btn-submit {
                width: 100% !important;
            }
        }

    </style>
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#16a34a" />
    <link rel="apple-touch-icon" href="/icons/icon-192x192.png" />
</head>
<body>
    <div class="page-wrapper">
        <div class="left-panel">
            <div class="logo">Habit<span>Flow</span></div>
            <div class="left-content">
                <h1>Починай будувати кращі звички сьогодні</h1>
                <p>Математичний аналіз поведінки та персональні рекомендації.</p>
            </div>
            <div class="features">
                <div class="feature-item">
                    <div class="feature-icon">📊</div>
                    <span>Математичний аналіз прогресу</span>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">🤖</div>
                    <span>Персональні рекомендації під тебе</span>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">🎯</div>
                    <span>Прогноз дати формування звички</span>
                </div>
            </div>
        </div>
        <div class="right-panel">
            <div class="form-header">
                <h2>Створити акаунт</h2>
                <p>Вже маєш акаунт? <a asp-controller="Auth" asp-action="Login">Увійти</a></p>
            </div>
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="validation-summary">
                    @Html.ValidationSummary(true)
                </div>
            }
            <form asp-controller="Auth" asp-action="Register" method="post">
                <div class="form-group">
                    <label asp-for="Name">Ім'я</label>
                    <input asp-for="Name" placeholder="Ім'я" />
                    <span asp-validation-for="Name" class="error-message"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Email">Електронна пошта</label>
                    <input asp-for="Email" type="email" placeholder="Твоя електронна пошта@email.com" />
                    <span asp-validation-for="Email" class="error-message"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Password">Пароль</label>
                    <input asp-for="Password" type="password" placeholder="Мінімум 6 символів" />
                    <span asp-validation-for="Password" class="error-message"></span>
                </div>
                <div class="form-group">
                    <label asp-for="ConfirmPassword">Підтвердити пароль</label>
                    <input asp-for="ConfirmPassword" type="password" placeholder="Повтори пароль" />
                    <span asp-validation-for="ConfirmPassword" class="error-message"></span>
                </div>
                <button type="submit" class="btn-submit">Зареєструватись →</button>
            </form>
        </div>
    </div>
    <script>
            if ('serviceWorker' in navigator) {
              navigator.serviceWorker.register('/service-worker.js');
            }
    </script>
</body>
</html>
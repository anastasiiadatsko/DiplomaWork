@{
    ViewData["Title"] = "Реєстрація успішна";
    Layout = null;
}
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <title>HabitFlow — Перевір пошту</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; background: #f0fdf4; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .card { background: white; border-radius: 24px; padding: 60px 48px; text-align: center; max-width: 480px; width: 100%; margin: 24px; box-shadow: 0 4px 40px rgba(0,0,0,0.08); }
        .icon { font-size: 56px; margin-bottom: 20px; }
        h1 { font-size: 24px; font-weight: 700; color: #111827; margin-bottom: 12px; }
        p { font-size: 15px; color: #6b7280; line-height: 1.6; margin-bottom: 28px; }
        .email-badge { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 10px; padding: 12px 20px; font-size: 14px; color: #16a34a; font-weight: 500; margin-bottom: 28px; display: inline-block; }
        a { color: #16a34a; font-size: 14px; text-decoration: none; }
    </style>
</head>
<body>
    <div class="card">
        <div class="icon">📬</div>
        <h1>Перевір свою пошту!</h1>
        <p>Ми відправили лист з посиланням для підтвердження. Натисни на кнопку в листі щоб активувати акаунт.</p>
        <div class="email-badge">✉️ Лист відправлено</div>
        <br />
        <a asp-controller="Auth" asp-action="Login">← Повернутись до входу</a>
    </div>
</body>
</html>
@model HabitFlow.BLL.DTOs.ResetPasswordDto
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <title>HabitFlow — Новий пароль</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; background: #f0fdf4; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .card { background: white; border-radius: 24px; padding: 48px; max-width: 440px; width: 100%; margin: 24px; box-shadow: 0 4px 40px rgba(0,0,0,0.08); }
        .icon { font-size: 40px; margin-bottom: 16px; }
        h1 { font-size: 22px; font-weight: 700; color: #111827; margin-bottom: 8px; }
        p { font-size: 14px; color: #6b7280; margin-bottom: 28px; }
        label { display: block; font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 6px; }
        input { width: 100%; padding: 11px 14px; border: 1.5px solid #e5e7eb; border-radius: 10px; font-family: 'Inter', sans-serif; font-size: 14px; outline: none; transition: border-color 0.2s; background: #f9fafb; margin-bottom: 14px; }
        input:focus { border-color: #16a34a; background: white; }
        .error { font-size: 12px; color: #dc2626; margin-top: -10px; margin-bottom: 10px; display: block; }
        .validation-summary { background: #fef2f2; border: 1px solid #fecaca; border-radius: 10px; padding: 12px; margin-bottom: 16px; font-size: 13px; color: #dc2626; }
        .btn { width: 100%; padding: 12px; background: #16a34a; color: white; border: none; border-radius: 10px; font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 600; cursor: pointer; }
        .btn:hover { background: #15803d; }
    </style>
</head>
<body>
    <div class="card">
        <div class="icon">🔑</div>
        <h1>Новий пароль</h1>
        <p>Введи новий пароль для свого акаунту.</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="validation-summary">@Html.ValidationSummary(true)</div>
        }

        <form asp-controller="Auth" asp-action="ResetPassword" method="post">
            <input asp-for="Token" type="hidden" />
            <input asp-for="Email" type="hidden" />
            <label asp-for="NewPassword">Новий пароль</label>
            <input asp-for="NewPassword" type="password" placeholder="Мінімум 6 символів" />
            <span asp-validation-for="NewPassword" class="error"></span>
            <label asp-for="ConfirmPassword">Підтвердити пароль</label>
            <input asp-for="ConfirmPassword" type="password" placeholder="Повтори пароль" />
            <span asp-validation-for="ConfirmPassword" class="error"></span>
            <button type="submit" class="btn">Зберегти пароль →</button>
        </form>
    </div>
</body>
</html>
@{
    ViewData["Title"] = "Email підтверджено";
    Layout = null;
}
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <title>HabitFlow — Email підтверджено</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; background: #f0fdf4; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .card { background: white; border-radius: 24px; padding: 60px 48px; text-align: center; max-width: 480px; width: 100%; margin: 24px; box-shadow: 0 4px 40px rgba(0,0,0,0.08); }
        .icon { font-size: 56px; margin-bottom: 20px; }
        h1 { font-size: 24px; font-weight: 700; color: #111827; margin-bottom: 12px; }
        p { font-size: 15px; color: #6b7280; line-height: 1.6; margin-bottom: 28px; }
        .btn { display: inline-block; background: #16a34a; color: white; padding: 12px 32px; border-radius: 10px; font-size: 15px; font-weight: 600; text-decoration: none; }
        .btn:hover { background: #15803d; }
    </style>
</head>
<body>
    <div class="card">
        <div class="icon">🎉</div>
        <h1>Email підтверджено!</h1>
        <p>Твій акаунт успішно активований. Тепер можеш увійти і почати будувати звички!</p>
        <a asp-controller="Auth" asp-action="Login" class="btn">Увійти →</a>
    </div>
</body>
</html>
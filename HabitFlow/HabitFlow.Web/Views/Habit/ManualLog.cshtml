@{
    Layout = null;
    var habitId = ViewBag.HabitId as Guid? ?? Guid.Empty;
    var habitName = ViewBag.HabitName as string ?? "Звичка";
    var habitColor = ViewBag.HabitColor as string ?? "#16a34a";
    var habitStartDate = ViewBag.HabitStartDate as string ?? DateTime.Today.ToString("yyyy-MM-dd");
    var todayStr = DateTime.Today.ToString("yyyy-MM-dd");
    var defaultFromDate = DateTime.Today.AddDays(-6).ToString("yyyy-MM-dd");

    if (string.Compare(defaultFromDate, habitStartDate, StringComparison.Ordinal) < 0)
    {
        defaultFromDate = habitStartDate;
    }

    var success = TempData["Success"] as string;
    var error = TempData["Error"] as string;
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Додати виконання — @habitName</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Inter, sans-serif;
            background: #f0fdf4;
            color: #111827;
            min-height: 100vh;
        }

        .navbar {
            background: white;
            padding: 14px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 2px 8px rgba(0,0,0,.05);
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .logo {
            font-size: 20px;
            font-weight: 700;
            color: #16a34a;
            text-decoration: none;
        }

        .nav-links {
            display: flex;
            gap: 8px;
        }

        .nav-link,
        .btn-logout {
            text-decoration: none;
            padding: 8px 14px;
            border-radius: 10px;
            color: #374151;
            background: #f9fafb;
            font-size: 14px;
            border: none;
            cursor: pointer;
        }

        .container {
            max-width: 620px;
            margin: 40px auto;
            padding: 0 20px 60px;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: #6b7280;
            text-decoration: none;
            font-size: 14px;
            margin-bottom: 20px;
        }

            .back-link:hover {
                color: #111827;
            }

        .page-title {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 6px;
        }

        .habit-dot {
            width: 14px;
            height: 14px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .page-subtitle {
            color: #6b7280;
            font-size: 14px;
            margin-bottom: 28px;
        }

        .alert {
            padding: 14px 18px;
            border-radius: 12px;
            font-size: 14px;
            margin-bottom: 20px;
            font-weight: 500;
        }

        .alert-success {
            background: #dcfce7;
            color: #15803d;
            border: 1px solid #bbf7d0;
        }

        .alert-error {
            background: #fee2e2;
            color: #dc2626;
            border: 1px solid #fecaca;
        }

        .card {
            background: white;
            border-radius: 20px;
            padding: 28px;
            box-shadow: 0 2px 14px rgba(0,0,0,.06);
            margin-bottom: 16px;
        }

        .card-title {
            font-size: 16px;
            font-weight: 700;
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .form-group {
            margin-bottom: 18px;
        }

        label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: #374151;
            margin-bottom: 6px;
        }

        input[type="date"],
        textarea {
            width: 100%;
            padding: 11px 14px;
            border: 1.5px solid #e5e7eb;
            border-radius: 10px;
            font-size: 14px;
            font-family: inherit;
            color: #111827;
            background: #fafafa;
            transition: border-color 0.2s;
            outline: none;
        }

            input[type="date"]:focus,
            textarea:focus {
                border-color: #16a34a;
                background: white;
            }

        textarea {
            resize: vertical;
            min-height: 80px;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 12px 22px;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            text-decoration: none;
            transition: opacity 0.15s;
        }

            .btn:hover {
                opacity: 0.88;
            }

        .btn-primary {
            background: #16a34a;
            color: white;
            width: 100%;
        }

        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 20px 0;
            color: #9ca3af;
            font-size: 13px;
        }

            .divider::before,
            .divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: #e5e7eb;
            }

        .range-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .btn-secondary {
            background: #f0fdf4;
            color: #16a34a;
            border: 1.5px solid #bbf7d0;
            width: 100%;
        }

        @@media (max-width: 480px) {
            .range-row {
                grid-template-columns: 1fr;
            }

            .navbar {
                padding: 12px 16px;
            }
        }
    </style>
</head>
<body>

    <nav class="navbar">
        <a asp-controller="Dashboard" asp-action="Index" class="logo">HabitFlow</a>
        <div class="nav-links">
            <a asp-controller="Dashboard" asp-action="Index" class="nav-link">🏠 Дошка</a>
            <a asp-controller="Habit" asp-action="Index" class="nav-link">📋 Звички</a>
            <form asp-controller="Auth" asp-action="Logout" method="post">
                <button type="submit" class="btn-logout">Вийти</button>
            </form>
        </div>
    </nav>

    <div class="container">

        <a href="javascript:history.back()" class="back-link">← Назад</a>

        <div class="page-title">
            <span class="habit-dot" style="background:@habitColor"></span>
            @habitName
        </div>

        <div class="page-subtitle">Додай виконання вручну — для одного дня або діапазону</div>

        @if (!string.IsNullOrEmpty(success))
        {
            <div class="alert alert-success">✅ @success</div>
        }

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-error">⚠️ @error</div>
        }

        <div class="card">
            <div class="card-title">📅 Один день</div>

            <form method="post" action="/Habit/ManualLog">
                <input type="hidden" name="HabitId" value="@habitId" />

                <div class="form-group">
                    <label for="single-date">Дата виконання</label>
                    <input type="date"
                           id="single-date"
                           name="Date"
                           value="@todayStr"
                           min="@habitStartDate"
                           max="@todayStr"
                           required />
                </div>

                <div class="form-group">
                    <label for="note">Нотатка (необов'язково)</label>
                    <textarea id="note" name="Note" placeholder="Як пройшло? Що відчула?"></textarea>
                </div>

                <button type="submit" class="btn btn-primary">
                    ✅ Додати виконання
                </button>
            </form>
        </div>

        <div class="divider">або</div>

        <div class="card">
            <div class="card-title">📆 Діапазон дат</div>

            <form method="post" action="/Habit/ManualLogRange">
                <input type="hidden" name="habitId" value="@habitId" />

                <div class="range-row">
                    <div class="form-group">
                        <label for="from-date">Від</label>
                        <input type="date"
                               id="from-date"
                               name="fromDate"
                               value="@defaultFromDate"
                               min="@habitStartDate"
                               max="@todayStr"
                               required />
                    </div>

                    <div class="form-group">
                        <label for="to-date">До</label>
                        <input type="date"
                               id="to-date"
                               name="toDate"
                               value="@todayStr"
                               min="@habitStartDate"
                               max="@todayStr"
                               required />
                    </div>
                </div>

                <button type="submit" class="btn btn-secondary">
                    📆 Додати діапазон
                </button>
            </form>
        </div>

    </div>

    <script>
        document.querySelector('form[action="/Habit/ManualLogRange"]')
            .addEventListener('submit', function (e) {
                const from = document.getElementById('from-date').value;
                const to = document.getElementById('to-date').value;

                if (from > to) {
                    e.preventDefault();
                    alert('Дата "Від" не може бути пізніше дати "До".');
                }
            });
    </script>

</body>
</html>
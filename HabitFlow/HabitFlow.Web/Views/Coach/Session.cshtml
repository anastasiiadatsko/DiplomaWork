@Html.AntiForgeryToken()
@model HabitFlow.BLL.DTOs.CoachSessionResponse
@{
    Layout = null;
    var habitId = ViewBag.HabitId;
    var habitName = ViewBag.HabitName as string ?? string.Empty;
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Коуч — @Model.SessionTitle</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body { font-family:Inter,sans-serif; background:#f0fdf4; min-height:100vh; }

        .navbar { background:white; padding:14px 30px; display:flex; justify-content:space-between;
            align-items:center; box-shadow:0 2px 8px rgba(0,0,0,.05); }
        .logo { font-size:20px; font-weight:700; color:#16a34a; text-decoration:none; }
        .nav-link { text-decoration:none; padding:8px 14px; border-radius:10px;
            color:#374151; background:#f9fafb; font-size:14px; }

        .container { max-width:700px; margin:0 auto; padding:32px 20px 60px; }

        /* ── Header ── */
        .coach-header { text-align:center; margin-bottom:32px; }
        .coach-emoji { font-size:52px; display:block; margin-bottom:12px; }
        .coach-title { font-size:22px; font-weight:700; margin-bottom:6px; }
        .coach-subtitle { color:#6b7280; font-size:14px; }

        /* ── Кроки анкети ── */
        .progress-bar { height:4px; background:#e5e7eb; border-radius:4px; margin-bottom:28px; }
        .progress-fill { height:100%; background:#16a34a; border-radius:4px;
            transition: width .4s ease; }

        /* ── Питання ── */
        .question-card { background:white; border-radius:20px; padding:28px;
            box-shadow:0 4px 20px rgba(0,0,0,.06); margin-bottom:16px;
            display:none; animation: fadeIn .3s ease; }
        .question-card.active { display:block; }
        @@keyframes fadeIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }

        .question-number { font-size:12px; color:#9ca3af; text-transform:uppercase;
            letter-spacing:.5px; margin-bottom:8px; }
        .question-text { font-size:18px; font-weight:600; margin-bottom:6px; line-height:1.4; }
        .question-hint { font-size:13px; color:#9ca3af; margin-bottom:18px; }

        textarea, input[type="text"] {
            width:100%; padding:14px; border:1.5px solid #e5e7eb; border-radius:12px;
            font-family:Inter,sans-serif; font-size:15px; resize:vertical; min-height:100px;
            transition: border-color .2s; outline:none; color:#111827;
        }
        textarea:focus, input[type="text"]:focus { border-color:#16a34a; }
        .skip-hint { font-size:12px; color:#d1d5db; margin-top:6px; }

        /* ── Кнопки навігації ── */
        .nav-buttons { display:flex; gap:12px; margin-top:20px; }
        .btn-prev { padding:13px 22px; background:#f9fafb; border:1.5px solid #e5e7eb;
            border-radius:12px; cursor:pointer; font-size:14px; font-weight:500;
            color:#374151; }
        .btn-next { flex:1; padding:13px; background:#16a34a; color:white;
            border:none; border-radius:12px; cursor:pointer; font-size:15px;
            font-weight:600; transition: background .2s; }
        .btn-next:hover { background:#15803d; }
        .btn-next:disabled { background:#d1fae5; cursor:not-allowed; }

        /* ── Результат (порада) ── */
        .advice-card { background:white; border-radius:20px; padding:28px;
            box-shadow:0 4px 20px rgba(0,0,0,.06); display:none; }
        .advice-card.visible { display:block; animation: fadeIn .4s ease; }

        .advice-loading { text-align:center; padding:20px; }
        .spinner { width:36px; height:36px; border:3px solid #d1fae5;
            border-top-color:#16a34a; border-radius:50%; margin:0 auto 12px;
            animation: spin .8s linear infinite; }
        @@keyframes spin { to { transform:rotate(360deg); } }
        .loading-text { color:#6b7280; font-size:14px; }

        .advice-title { font-weight:700; font-size:16px; margin-bottom:14px;
            display:flex; align-items:center; gap:8px; }
        .advice-text { font-size:15px; color:#374151; line-height:1.7; margin-bottom:20px; }

        .action-items { background:#f0fdf4; border-radius:14px; padding:16px; margin-bottom:18px; }
        .action-title { font-weight:600; font-size:13px; color:#15803d;
            margin-bottom:10px; text-transform:uppercase; letter-spacing:.5px; }
        .action-item { display:flex; align-items:flex-start; gap:10px;
            margin-bottom:8px; font-size:14px; color:#374151; }
        .action-check { width:20px; height:20px; background:#16a34a; border-radius:50%;
            display:flex; align-items:center; justify-content:center; flex-shrink:0;
            margin-top:1px; }
        .action-check::after { content:'✓'; color:white; font-size:11px; font-weight:700; }

        .motivation-box { background:linear-gradient(135deg, #ecfdf5, #d1fae5);
            border-radius:14px; padding:16px; text-align:center;
            font-size:14px; color:#065f46; font-style:italic; margin-bottom:20px; }

        /* ── Кнопки після поради ── */
        .after-advice-buttons { display:flex; flex-direction:column; gap:10px; }
        .btn-chat { padding:13px; background:white; border:1.5px solid #16a34a;
            color:#16a34a; border-radius:12px; cursor:pointer; font-size:14px;
            font-weight:600; text-align:center; }
        .btn-back { padding:13px; background:#f9fafb; border:1.5px solid #e5e7eb;
            color:#6b7280; border-radius:12px; cursor:pointer; font-size:14px;
            text-align:center; text-decoration:none; display:block; }

        /* ── Free Chat ── */
        .chat-section { display:none; }
        .chat-section.visible { display:block; margin-top:20px; }
        .chat-messages { max-height:350px; overflow-y:auto; margin-bottom:16px;
            display:flex; flex-direction:column; gap:12px; }

        .msg { max-width:85%; padding:12px 16px; border-radius:16px; font-size:14px;
            line-height:1.6; }
        .msg-user { background:#16a34a; color:white; align-self:flex-end;
            border-bottom-right-radius:4px; }
        .msg-coach { background:white; color:#374151; align-self:flex-start;
            border:1px solid #e5e7eb; border-bottom-left-radius:4px; }
        .msg-loading { background:#f9fafb; color:#9ca3af; align-self:flex-start; }

        .chat-input-row { display:flex; gap:10px; }
        .chat-input { flex:1; padding:12px 16px; border:1.5px solid #e5e7eb;
            border-radius:12px; font-size:14px; font-family:Inter,sans-serif;
            outline:none; resize:none; min-height:48px; max-height:120px; }
        .chat-input:focus { border-color:#16a34a; }
        .btn-send { padding:12px 18px; background:#16a34a; color:white;
            border:none; border-radius:12px; cursor:pointer; font-size:18px; }
        .btn-send:disabled { background:#d1fae5; cursor:not-allowed; }
    </style>
</head>
<body>

    <nav class="navbar">
        <a asp-controller="Dashboard" asp-action="Index" class="logo">HabitFlow</a>
        <a asp-controller="Analytics" asp-action="Index" asp-route-id="@habitId" class="nav-link">
            ← Аналітика
        </a>
    </nav>

    <div class="container">

        <div class="coach-header">
            <span class="coach-emoji">@Model.SessionEmoji</span>
            <div class="coach-title">@Model.SessionTitle</div>
            <div class="coach-subtitle">
                @(Model.SessionType switch
                {
                    HabitFlow.BLL.DTOs.CoachSessionType.Onboarding => "Відповідай чесно — це тільки для тебе",
                    HabitFlow.BLL.DTOs.CoachSessionType.WeeklyCheckIn => "Тижневий огляд твоїх звичок",
                    HabitFlow.BLL.DTOs.CoachSessionType.AfterStreakBreak => "Давай розберемось що сталось і як рухатись далі",
                    HabitFlow.BLL.DTOs.CoachSessionType.MilestoneReached => "Відзнач цей момент — ти цього заслуговуєш",
                    _ => "Запитай свого особистого коуча",
                })
            </div>
        </div>

        <div class="progress-bar">
            <div class="progress-fill" id="progressFill" style="width:0%"></div>
        </div>

        <div id="questionsContainer">
            @for (int i = 0; i < Model.Questions.Count; i++)
            {
                var q = Model.Questions[i];
                <div class="question-card @(i == 0 ? "active" : "")"
                     id="question-@i"
                     data-question-id="@q.Id"
                     data-required="@q.IsRequired.ToString().ToLower()">

                    <div class="question-number">Питання @(i + 1) з @Model.Questions.Count</div>
                    @{
                        var questionText = q.Text
                        .Replace("«»", $"«{habitName}»")
                        .Replace("« »", $"«{habitName}»")
                        .Replace("{habitName}", habitName);
                    }

                    <div class="question-text">@questionText</div>
                    @if (!string.IsNullOrEmpty(q.Hint))
                    {
                        <div class="question-hint">@q.Hint</div>
                    }

                    <textarea class="answer-input"
                              placeholder="Твоя відповідь..."
                              rows="3"></textarea>

                    @if (!q.IsRequired)
                    {
                        <div class="skip-hint">Це питання необов'язкове — можеш пропустити</div>
                    }

                    <div class="nav-buttons">
                        @if (i > 0)
                        {
                            <button class="btn-prev" onclick="prevQuestion(@i)">← Назад</button>
                        }
                        <button class="btn-next" id="btn-next-@i"
                                onclick="nextQuestion(@i, @Model.Questions.Count)">
                            @(i == Model.Questions.Count - 1 ? "Отримати пораду 🚀" : "Далі →")
                        </button>
                    </div>
                </div>
            }
        </div>

        <div class="advice-card" id="adviceCard">

            <div class="advice-loading" id="adviceLoading">
                <div class="spinner"></div>
                <div class="loading-text">Коуч аналізує твої відповіді...</div>
            </div>

            <div id="adviceContent" style="display:none">
                <div class="advice-title">🤖 Порада коуча</div>
                <div class="advice-text" id="adviceText"></div>

                <div class="action-items" id="actionItemsBlock">
                    <div class="action-title">Конкретні кроки</div>
                    <div id="actionItemsList"></div>
                </div>

                <div class="motivation-box" id="motivationBox"></div>

                <div class="after-advice-buttons">
                    <button class="btn-chat" onclick="showChat()">
                        💬 Продовжити розмову з коучем
                    </button>
                    <a asp-controller="Analytics" asp-action="Index"
                       asp-route-id="@habitId" class="btn-back">
                        ← Повернутись до аналітики
                    </a>
                </div>
            </div>
        </div>

        <!-- Free Chat -->
        <div class="chat-section" id="chatSection">
            <div class="advice-title" style="margin-top:0">💬 Продовж розмову</div>
            <div class="chat-messages" id="chatMessages"></div>
            <div class="chat-input-row">
                <textarea class="chat-input" id="chatInput"
                          placeholder="Запитай ще щось..."
                          rows="1"
                          onkeydown="handleChatKey(event)"></textarea>
                <button class="btn-send" id="btnSend" onclick="sendChat()">➤</button>
            </div>
        </div>

    </div>

    <script>
        const HABIT_ID    = '@habitId';
        const SESSION_TYPE = '@((int)Model.SessionType)';
        const TOKEN        = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        const totalQ       = @Model.Questions.Count;

        let answers  = [];
        let history  = [];
        let currentQ = 0;

        function nextQuestion(idx, total) {
            const card     = document.getElementById(`question-${idx}`);
            const textarea = card.querySelector('.answer-input');
            const required = card.dataset.required === 'true';
            const qId      = card.dataset.questionId;

            if (required && !textarea.value.trim()) {
                textarea.style.borderColor = '#ef4444';
                textarea.placeholder = 'Будь ласка, дай відповідь на це питання';
                return;
            }

            const existing = answers.findIndex(a => a.questionId === qId);
            if (existing >= 0)
                answers[existing].answer = textarea.value.trim();
            else
                answers.push({ questionId: qId, answer: textarea.value.trim() });

            if (idx + 1 >= total) {
                submitAnswers();
            } else {
                card.classList.remove('active');
                document.getElementById(`question-${idx + 1}`).classList.add('active');
                currentQ = idx + 1;
                updateProgress();
            }
        }

        function prevQuestion(idx) {
            document.getElementById(`question-${idx}`).classList.remove('active');
            document.getElementById(`question-${idx - 1}`).classList.add('active');
            currentQ = idx - 1;
            updateProgress();
        }

        function updateProgress() {
            const pct = Math.round((currentQ / totalQ) * 100);
            document.getElementById('progressFill').style.width = pct + '%';
        }

        async function submitAnswers() {
            document.getElementById('questionsContainer').style.display = 'none';
            const card = document.getElementById('adviceCard');
            card.classList.add('visible');
            document.getElementById('progressFill').style.width = '100%';

            try {
                const resp = await fetch('/Coach/Advice', {
                    method: 'POST',
                    headers: {
                        'Content-Type':       'application/json',
                    },
                    body: JSON.stringify({
                        habitId:     HABIT_ID,
                        sessionType: parseInt(SESSION_TYPE),
                        answers:     answers,
                        history:     [],
                    }),
                });

                if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
                const data = await resp.json();
                renderAdvice(data);

                history.push({
                    role:    'user',
                    content: answers.map(a => `${a.questionId}: ${a.answer}`).join('\n'),
                });
                history.push({
                    role:    'model',
                    content: data.advice,
                });

            } catch (err) {
                console.error(err);
                renderAdvice({
                    advice: 'На жаль, виникла помилка. Спробуй ще раз.',
                    actionItems: [],
                    motivation: '',
                });
            }
        }

        function renderAdvice(data) {
            document.getElementById('adviceLoading').style.display = 'none';
            document.getElementById('adviceContent').style.display = 'block';
            document.getElementById('adviceText').textContent = data.advice;

            const list = document.getElementById('actionItemsList');
            list.innerHTML = '';
            if (data.actionItems && data.actionItems.length > 0) {
                data.actionItems.forEach(item => {
                    list.innerHTML += `
                        <div class="action-item">
                            <div class="action-check"></div>
                            <span>${item}</span>
                        </div>`;
                });
                document.getElementById('actionItemsBlock').style.display = 'block';
            } else {
                document.getElementById('actionItemsBlock').style.display = 'none';
            }

            if (data.motivation) {
                document.getElementById('motivationBox').textContent = `"${data.motivation}"`;
                document.getElementById('motivationBox').style.display = 'block';
            } else {
                document.getElementById('motivationBox').style.display = 'none';
            }
        }

        function showChat() {
            document.getElementById('chatSection').classList.add('visible');

            const lastAdvice = document.getElementById('adviceText').textContent;
            if (lastAdvice) {
                appendMessage('coach', lastAdvice);
            }

            document.getElementById('chatInput').focus();
        }

        function handleChatKey(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendChat();
            }
        }

        async function sendChat() {
            const input = document.getElementById('chatInput');
            const text  = input.value.trim();
            if (!text) return;

            input.value = '';
            document.getElementById('btnSend').disabled = true;
            appendMessage('user', text);

            const loadingId = 'loading-' + Date.now();
            appendMessage('loading', '...', loadingId);

            history.push({ role: 'user', content: text });

            try {
                const resp = await fetch('/Coach/Chat', {
                    method: 'POST',
                    headers: {
                        'Content-Type':             'application/json',
                    },
                    body: JSON.stringify({
                        habitId:      HABIT_ID,
                        sessionType:  5, // FreeChat
                        answers:      [],
                        history:      history.slice(-10),
                        userMessage:  text,
                    }),
                });

                const data = await resp.json();

                document.getElementById(loadingId)?.remove();

                const reply = data.advice || 'Вибач, не можу відповісти зараз.';
                appendMessage('coach', reply);
                history.push({ role: 'model', content: reply });

            } catch (err) {
                document.getElementById(loadingId)?.remove();
                appendMessage('coach', 'Виникла помилка. Спробуй ще раз.');
            }

            document.getElementById('btnSend').disabled = false;
            input.focus();
        }

        function appendMessage(type, text, id) {
            const container = document.getElementById('chatMessages');
            const div = document.createElement('div');
            if (id) div.id = id;

            div.className = type === 'user' ? 'msg msg-user'
                : type === 'loading'        ? 'msg msg-loading'
                : 'msg msg-coach';

            div.textContent = text;
            container.appendChild(div);
            container.scrollTop = container.scrollHeight;
        }

        document.querySelectorAll('textarea').forEach(t => {
            t.addEventListener('input', function() {
                this.style.height = 'auto';
                this.style.height = Math.min(this.scrollHeight, 200) + 'px';
                if (this.style.borderColor === 'rgb(239, 68, 68)')
                    this.style.borderColor = '';
            });
        });

        updateProgress();
    </script>

</body>
</html>

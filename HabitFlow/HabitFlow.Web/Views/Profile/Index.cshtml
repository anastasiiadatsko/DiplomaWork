@using HabitFlow.BLL.DTOs
@using System.Text
@model ProfileViewModel
@{
    Layout = null;
    var level = Model.StarLevel;
    var count = Model.TotalCompletedHabits;

    // Розрахунок параметрів для SVG
    var glowSize = level * 8 + 10;
    var starScale = 0.4 + (level - 1) * 0.15;
    var glowOpacity = 0.2 + (level - 1) * 0.18;
    var glowColor = "#facc15";

    // Функція для генерації точок зірки
    string GetStarPoints(int centerX, int centerY, int size)
    {
        var outer = size;
        var inner = size * 0.42;
        var pts = new StringBuilder();
        for (int i = 0; i < 10; i++)
        {
            var angle = (i * 36 - 90) * Math.PI / 180;
            var r = i % 2 == 0 ? outer : inner;
            var x = centerX + r * Math.Cos(angle);
            var y = centerY + r * Math.Sin(angle);
            pts.Append($"{x.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)},{y.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)} ");
        }
        return pts.ToString().Trim();
    }
}
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>HabitFlow — Профіль</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background: #f0fdf4;
            min-height: 100vh;
            color: #111827;
        }

        .navbar {
            background: white;
            padding: 14px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 1px 8px rgba(0,0,0,0.06);
        }
        .logo { font-size: 20px; font-weight: 700; color: #16a34a; text-decoration: none; }
        .nav-links { display: flex; gap: 12px; align-items: center; }
        .nav-link { font-size: 14px; color: #374151; text-decoration: none; font-weight: 500; padding: 7px 14px; border-radius: 8px; }
        .nav-link:hover { background: #f3f4f6; }
        .btn-logout { padding: 8px 16px; background: #f3f4f6; color: #374151; border-radius: 8px; font-size: 13px; font-weight: 500; text-decoration: none; }

        .page-container {
            max-width: 1100px;
            margin: 32px auto;
            padding: 0 24px;
            display: grid;
            grid-template-columns: 320px 1fr;
            gap: 24px;
            align-items: start;
        }

        /* ============ CHARACTER CARD ============ */
        .character-card {
            background: white;
            border-radius: 24px;
            padding: 28px 20px;
            box-shadow: 0 4px 25px rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            position: sticky;
            top: 24px;
        }

        .char-name { font-size: 20px; font-weight: 700; margin-bottom: 4px; }
        .char-level-badge {
            font-size: 12px; font-weight: 600; color: #16a34a;
            background: #dcfce7; padding: 4px 12px; border-radius: 100px; margin-bottom: 20px;
        }

        .char-figure-wrapper {
            width: 180px; height: 220px;
            position: relative; margin: 0 auto 20px;
            animation: float 3.5s ease-in-out infinite;
        }

        @@keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        .char-svg { width: 100%; height: 100%; }

        @if (level >= 4) {
            <text>
            .star-group { animation: pulse-star 1.8s ease-in-out infinite; transform-origin: center; }
            @@keyframes pulse-star {
                0%, 100% { transform: scale(1); opacity: 1; }
                50% { transform: scale(1.1); opacity: 0.9; }
            }
            </text>
        }

        @if (level == 5) {
            <text>
            .char-svg { animation: glow-pulse 2s ease-in-out infinite; }
            @@keyframes glow-pulse {
                0%, 100% { filter: drop-shadow(0 0 10px rgba(250,204,21,0.4)); }
                50% { filter: drop-shadow(0 0 25px rgba(250,204,21,0.8)); }
            }
            </text>
        }

        /* PROGRESS BAR */
        .level-progress { width: 100%; margin-bottom: 20px; }
        .level-progress-header { display: flex; justify-content: space-between; font-size: 12px; color: #9ca3af; margin-bottom: 6px; }
        .progress-track { width: 100%; height: 8px; background: #f3f4f6; border-radius: 10px; overflow: hidden; }
        .progress-fill { height: 100%; background: linear-gradient(90deg, #facc15, #f59e0b); border-radius: 10px; transition: width 1s ease-in-out; }

        /* STATS MINI */
        .stats-mini { display: flex; gap: 8px; width: 100%; margin-bottom: 20px; }
        .stat-mini { flex: 1; background: #f9fafb; border-radius: 14px; padding: 12px 4px; }
        .stat-mini-val { font-size: 18px; font-weight: 700; display: block; }
        .stat-mini-label { font-size: 10px; color: #9ca3af; text-transform: uppercase; }

        /* LEVEL LIST */
        .level-list { width: 100%; text-align: left; }
        .level-item { display: flex; align-items: center; gap: 10px; padding: 8px; border-radius: 12px; margin-bottom: 4px; border: 1px solid transparent; }
        .level-item.current { background: #f0fdf4; border-color: #bbf7d0; }
        .level-item.done { opacity: 0.6; }
        .level-text { flex: 1; }
        .level-title { font-size: 13px; font-weight: 600; }
        .level-req { font-size: 11px; color: #9ca3af; }
        .level-tag { font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 8px; }
        .tag-current { background: #dcfce7; color: #16a34a; }
        .tag-done { background: #fef9c3; color: #ca8a04; }
        .tag-locked { background: #f3f4f6; color: #9ca3af; }

        /* ============ RIGHT COLUMN ============ */
        .right-col { display: flex; flex-direction: column; gap: 20px; }
        .card { background: white; border-radius: 20px; padding: 24px; box-shadow: 0 2px 12px rgba(0,0,0,0.04); }
        .card-title { font-size: 16px; font-weight: 700; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }

        .info-row { display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid #f3f4f6; }
        .info-row:last-child { border-bottom: none; }
        .info-label { color: #9ca3af; font-size: 14px; }
        .info-value { font-weight: 500; font-size: 14px; }

        /* FORM STYLES */
        .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .form-group { display: flex; flex-direction: column; gap: 6px; }
        .form-full { grid-column: 1 / -1; }
        .form-label { font-size: 12px; font-weight: 700; color: #4b5563; }
        .form-input { 
            padding: 12px; border: 1.5px solid #e5e7eb; border-radius: 10px; 
            font-size: 14px; transition: all 0.2s; background: #f9fafb;
        }
        .form-input:focus { outline: none; border-color: #16a34a; background: white; box-shadow: 0 0 0 3px rgba(22,163,74,0.1); }
        
        .btn-save { 
            background: #16a34a; color: white; border: none; padding: 12px 24px; 
            border-radius: 10px; font-weight: 600; cursor: pointer; transition: 0.2s;
        }
        .btn-save:hover { background: #15803d; transform: translateY(-1px); }

        /* ACHIEVEMENTS */
        .achievements-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 12px; }
        .achievement { 
            padding: 16px; border-radius: 16px; text-align: center; 
            background: #f9fafb; border: 1.5px solid #f3f4f6; transition: 0.3s;
        }
        .achievement.unlocked { background: #f0fdf4; border-color: #bbf7d0; }
        .achievement-icon { font-size: 32px; margin-bottom: 8px; display: block; }
        .achievement-name { font-size: 12px; font-weight: 700; margin-bottom: 4px; }
        .achievement-desc { font-size: 10px; color: #9ca3af; line-height: 1.3; }
        .achievement.locked { opacity: 0.7; }
        .achievement.locked .achievement-icon { filter: grayscale(1); opacity: 0.4; }

        /* GOAL BOX */
        .goal-box { display: flex; gap: 16px; background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 16px; padding: 20px; }
        .goal-icon-big { font-size: 32px; }
        .goal-name-text { font-size: 16px; font-weight: 700; color: #15803d; }
        .goal-time-text { font-size: 13px; color: #6b7280; margin-top: 4px; }

        .toast { padding: 12px 16px; border-radius: 12px; margin-bottom: 16px; font-size: 14px; font-weight: 500; }
        .toast-success { background: #dcfce7; color: #15803d; border: 1px solid #bbf7d0; }
    </style>
</head>
<body>

<nav class="navbar">
    <a asp-controller="Dashboard" asp-action="Index" class="logo">HabitFlow</a>
    <div class="nav-links">
        <a asp-controller="Dashboard" asp-action="Index" class="nav-link">🏠 Дашборд</a>
        <a asp-controller="Auth" asp-action="Logout" class="btn-logout">Вийти</a>
    </div>
</nav>

<div class="page-container">
    <aside class="character-card">
        <div class="char-name">@Model.User.Name</div>
        <div class="char-level-badge">@Model.StarLevelName</div>

        <div class="char-figure-wrapper">
            <svg class="char-svg" viewBox="0 0 180 220">
                <defs>
                    <radialGradient id="bodyFrost" cx="35%" cy="30%" r="70%">
                        <stop offset="0%" stop-color="#ffffff" stop-opacity="0.9"/>
                        <stop offset="100%" stop-color="#a7f3d0" stop-opacity="0.6"/>
                    </radialGradient>
                    <filter id="starGlowFilter">
                        <feGaussianBlur stdDeviation="@(level + 1)" result="glow"/>
                        <feMerge><feMergeNode in="glow"/><feMergeNode in="SourceGraphic"/></feMerge>
                    </filter>
                </defs>

                <ellipse cx="90" cy="140" rx="45" ry="55" fill="url(#bodyFrost)" stroke="#6ee7b7" stroke-width="1.5" />
                <ellipse cx="90" cy="70" rx="42" ry="46" fill="url(#bodyFrost)" stroke="#6ee7b7" stroke-width="1.5" />
                
                <circle cx="75" cy="68" r="6" fill="#1c1917" />
                <circle cx="105" cy="68" r="6" fill="#1c1917" />
                <path d="M 78 88 Q 90 98 102 88" stroke="#1c1917" stroke-width="2.5" fill="none" stroke-linecap="round"/>

                <circle cx="90" cy="145" r="@(15 + level * 6)" fill="@glowColor" opacity="@glowOpacity.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"/>

                <g class="star-group" filter="url(#starGlowFilter)">
                    @{ var sz = 18 + (level - 1) * 8; }
                    <polygon points="@GetStarPoints(90, 145, sz)" fill="#facc15" stroke="#f59e0b" stroke-width="1"/>
                </g>
            </svg>
        </div>

        @if (level < 5) {
            <div class="level-progress">
                <div class="level-progress-header">
                    <span>До рівня @(level + 1)</span>
                    <span>@count / @Model.NextLevelAt</span>
                </div>
                <div class="progress-track">
                    <div class="progress-fill" style="width: @Model.ProgressPercent.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                </div>
            </div>
        } else {
            <div class="char-level-badge" style="background:#fef9c3; color:#ca8a04">🏆 Максимальний рівень</div>
        }

        <div class="stats-mini">
            <div class="stat-mini"><span class="stat-mini-val">@count</span><span class="stat-mini-label">Виконано</span></div>
            <div class="stat-mini"><span class="stat-mini-val">@Model.TotalHabits</span><span class="stat-mini-label">Звичок</span></div>
            <div class="stat-mini"><span class="stat-mini-val">@level</span><span class="stat-mini-label">Рівень</span></div>
        </div>

        <div class="level-list">
            @{
                var levels = new[] { ("✨", "Початківець", "0-5"), ("🌟", "На шляху", "6-20"), ("💫", "Зростаєш", "21-50"), ("⭐", "Майстер", "51-100"), ("🌠", "Легенда", "100+") };
                for (int i = 0; i < levels.Length; i++) {
                    var lvl = i + 1;
                    <div class="level-item @(lvl == level ? "current" : lvl < level ? "done" : "")">
                        <span>@levels[i].Item1</span>
                        <div class="level-text">
                            <div class="level-title">@levels[i].Item2</div>
                            <div class="level-req">@levels[i].Item3</div>
                        </div>
                        <span class="level-tag @(lvl == level ? "tag-current" : lvl < level ? "tag-done" : "tag-locked")">
                            @(lvl == level ? "Зараз" : lvl < level ? "✓" : "🔒")
                        </span>
                    </div>
                }
            }
        </div>
    </aside>

    <main class="right-col">
        @if (TempData["Success"] != null) { <div class="toast toast-success">@TempData["Success"]</div> }

        <section class="card">
            <div class="card-title">👤 Мій Акаунт</div>
            <div class="info-row"><span class="info-label">Email</span><span class="info-value">@Model.User.Email</span></div>
            <div class="info-row"><span class="info-label">Дата реєстрації</span><span class="info-value">@Model.User.CreatedAt.ToString("dd.MM.yyyy")</span></div>
            <div class="info-row"><span class="info-label">Часовий пояс</span><span class="info-value">@Model.User.TimeZone</span></div>
        </section>

        <section class="card">
            <div class="card-title">✏️ Редагувати профіль</div>
            <form asp-controller="Profile" asp-action="EditProfile" method="post" class="form-grid">
                <div class="form-group form-full">
                    <label class="form-label">Ім'я</label>
                    <input class="form-input" type="text" name="Name" value="@Model.User.Name" required />
                </div>
                <div class="form-group">
                    <label class="form-label">Часовий пояс</label>
                    <select class="form-input" name="TimeZone">
                        <option value="UTC+2">Київ (UTC+2)</option>
                        <option value="UTC">UTC</option>
                    </select>
                </div>
                <div class="form-group" style="flex-direction:row; align-items:center; padding-top:25px">
                    <input type="checkbox" name="NotificationsEnabled" value="true" @(Model.User.NotificationsEnabled ? "checked" : "") style="width:18px; height:18px; accent-color:#16a34a"/>
                    <label style="margin-left:8px; font-size:14px">Сповіщення</label>
                </div>
                <div class="form-full">
                    <button type="submit" class="btn-save">Оновити профіль</button>
                </div>
            </form>
        </section>

        <section class="card">
            <div class="card-title">🏆 Досягнення</div>
            <div class="achievements-grid">
                @foreach (var a in Model.Achievements) {
                    <div class="achievement @(a.IsUnlocked ? "unlocked" : "locked")">
                        <span class="achievement-icon">@a.Icon</span>
                        <div class="achievement-name">@a.Name</div>
                        <div class="achievement-desc">@a.Description</div>
                    </div>
                }
            </div>
        </section>

        <section class="card">
            <div class="card-title">🎯 Моя ціль</div>
            @if (Model.User.IsOnboardingCompleted) {
                <div class="goal-box">
                    <div class="goal-icon-big">🚀</div>
                    <div>
                        <div class="goal-name-text">@Model.User.OnboardingGoal</div>
                        <div class="goal-time-text">Час: @Model.User.OnboardingTime</div>
                    </div>
                </div>
            } else {
                <div style="text-align:center; padding:20px">
                    <p style="color:#9ca3af; margin-bottom:15px">Ціль ще не встановлена</p>
                    <a asp-controller="Onboarding" asp-action="Index" class="btn-save" style="text-decoration:none">Встановити ціль</a>
                </div>
            }
        </section>
    </main>
</div>

</body>
</html>